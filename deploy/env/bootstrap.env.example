# Provider credentials written into the SQLite settings table.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Create or update a default agent row directly in SQLite.
DEFAULT_AGENT_ENABLED=true
DEFAULT_AGENT_ID=agent-prod
DEFAULT_AGENT_NAME=Production Agent
DEFAULT_AGENT_PROVIDER=moonshot
DEFAULT_AGENT_MODEL=kimi-k2.5
DEFAULT_AGENT_ACTIVE=true

# One of these can be used:
DEFAULT_AGENT_SYSTEM_PROMPT=
DEFAULT_AGENT_SYSTEM_PROMPT_FILE=__CONFIG_DIR__/default-system-prompt.md
