# Required Feishu application settings.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional webhook mode settings.
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# Service settings.
FEISHU_BOT_PORT=1999
FEISHU_LOG_LEVEL=info
NODE_ENV=production

# Agent routing.
AGENT_ENABLED=true
AGENT_SERVER_URL=http://127.0.0.1:1997
AGENT_ID=agent-prod
