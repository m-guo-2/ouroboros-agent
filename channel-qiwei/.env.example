# ==================== 企微开放平台配置 ====================

# QiWe API 基础地址
QIWEI_API_BASE_URL=https://api.qiweapi.com

# QiWe 平台令牌（租户 token）
QIWEI_TOKEN=your_token_here

# QiWe 设备实例 GUID
QIWEI_GUID=your_guid_here

# ==================== 服务配置 ====================

# 服务端口
QIWEI_BOT_PORT=2000

# HTTP 请求超时（秒）
QIWEI_HTTP_TIMEOUT_SECONDS=25

# 日志级别（debug/info/warn/error）
QIWEI_LOG_LEVEL=info

# ==================== Agent 联动 ====================

# 是否开启 Agent 联动（默认 true）
AGENT_ENABLED=true

# Agent Server 地址
AGENT_SERVER_URL=http://localhost:1997

# 当前 bot 对应的 Agent ID（可选）
AGENT_ID=
